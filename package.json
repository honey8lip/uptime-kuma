{
  "name": "uptime-kuma",
  "version": "1.0.0",
  "description": "A fancy self-hosted monitoring tool",
  "author": "Louis Lam",
  "license": "MIT",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "dev-vite": "vite",
    "build": "vite build",
    "build-docker": "npm run build",
    "lint": "eslint --ext .js,.vue src server",
    "test": "node test/test.js",
    "mark-as-nightly": "node extra/mark-as-nightly.js",
    "reset-password": "node extra/reset-password.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "~1.8.9",
    "axios": "~1.3.6",
    "bcryptjs": "~2.4.3",
    "chardet": "~1.4.0",
    "cheerio": "1.0.0-rc.12",
    "chroma-js": "~2.4.2",
    "command-exists": "~1.2.9",
    "compare-versions": "~6.0.0",
    "compression": "~1.7.4",
    "croner": "~6.0.5",
    "dayjs": "~1.11.7",
    "express": "~4.18.2",
    "express-basic-auth": "~1.2.1",
    "form-data": "~4.0.0",
    "iconv-lite": "~0.6.3",
    "jsonwebtoken": "~9.0.0",
    "knex": "~2.4.2",
    "marked": "~5.0.2",
    "mqtt": "~4.3.7",
    "node-cloudflared-tunnel": "~1.0.9",
    "nodemailer": "~6.9.1",
    "notp": "~2.0.3",
    "ping": "~0.4.4",
    "prometheus-api-metrics": "~3.2.1",
    "socket.io": "~4.6.1",
    "socket.io-client": "~4.6.1",
    "sqlite3": "~5.1.6",
    "tar": "~6.1.13",
    "tcp-ping": "~0.1.1",
    "timezones-list": "~3.0.2",
    "tough-cookie": "~4.1.2",
    "vue-multiselect": "~3.0.0-beta.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "~4.1.0",
    "eslint": "~8.38.0",
    "eslint-plugin-vue": "~9.10.0",
    "nodemon": "~2.0.22",
    "sass": "~1.62.0",
    "vite": "~4.3.1",
    "vue": "~3.2.47",
    "vue-router": "~4.1.6",
    "vuex": "~4.1.0"
  },
  "nodemonConfig": {
    "watch": [
      "server"
    ],
    "ext": "js,mjs,json",
    "ignore": [
      "data/*"
    ],
    "delay": 500
  },
  "engines": {
    "node": ">=14",
    "npm": ">=7"
  }
}
